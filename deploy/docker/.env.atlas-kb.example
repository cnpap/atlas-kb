# atlas-kb managed block for ~/docker/.env
ATLAS_KB_REPO_DIR=/root/deploy/atlas-kb
ATLAS_KB_ENV_FILE=/root/docker/atlas-kb.env
ATLAS_KB_CADDY_CONFIG_FILE=/root/deploy/atlas-kb/deploy/caddy/Caddyfile
ATLAS_KB_ZOT_CONFIG_FILE=/root/deploy/atlas-kb/deploy/zot/config.json
ATLAS_KB_POSTGRES_BOOTSTRAP_SCRIPT=/root/deploy/atlas-kb/deploy/scripts/bootstrap-atlas-kb-postgres.sh
ATLAS_KB_RUSTFS_BOOTSTRAP_SCRIPT=/root/deploy/atlas-kb/deploy/scripts/bootstrap-rustfs.sh
DOCKER_STACK_DIR=/root/docker
ATLAS_KB_DATA_VOLUME_NAME=atlas-kb_atlas_kb_data
ATLAS_KB_DOMAIN=atlas-kb.apitype.com
ATLAS_KB_UPSTREAM=atlas-kb:8080
ATLAS_KB_WEB_UPSTREAM=minio:9000
ATLAS_KB_WEB_BUCKET=atlas-kb-web
ATLAS_KB_WEB_S3_ENDPOINT=http://minio:9000
ATLAS_KB_DB_USER=ops_agent_kit
ATLAS_KB_DB_PASSWORD=
ATLAS_KB_DB_NAME=ops_agent_kit
ATLAS_KB_IMAGE=127.0.0.1:5000/atlas-kb:latest
ATLAS_KB_BUILD_API_BASE_URL=/
