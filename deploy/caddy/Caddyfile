{
  admin off
  auto_https off
}

:7171 {
  @atlas_kb host {$ATLAS_KB_DOMAIN}
  @openvscode host ide.vmvm.cloud

  handle @atlas_kb {
    @api path /api /api/*

    handle @api {
      header {
        Cache-Control "private, no-store, no-cache, max-age=0, must-revalidate"
        Pragma "no-cache"
        Expires "0"
        Vary "Authorization, Origin"
      }
      reverse_proxy {$ATLAS_KB_UPSTREAM}
    }

    @static path_regexp static ^/(?:assets/.*|_nuxt/.*|favicon\.ico|robots\.txt|site\.webmanifest|manifest.*\.json|.*\.(?:js|mjs|css|map|json|txt|xml|png|jpg|jpeg|gif|svg|webp|avif|ico|woff2?|ttf|otf|eot))$
    handle @static {
      rewrite * /{$ATLAS_KB_WEB_BUCKET}{uri}
      reverse_proxy {$ATLAS_KB_WEB_UPSTREAM}
    }

    handle {
      header {
        Cache-Control "no-store, no-cache, max-age=0, must-revalidate"
        Pragma "no-cache"
        Expires "0"
      }
      rewrite * /{$ATLAS_KB_WEB_BUCKET}/index.html
      reverse_proxy {$ATLAS_KB_WEB_UPSTREAM}
    }
  }

  handle @openvscode {
    reverse_proxy 192.168.99.209:7171 {
      header_up X-Forwarded-Proto https
      header_up X-Forwarded-Port 443
    }
  }

  handle {
    respond "unknown host" 404
  }

  log {
    output stdout
    format json
  }
}
