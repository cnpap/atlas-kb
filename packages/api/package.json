{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@atlas-kb/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "start": "bun run src/server.ts",
    "build": "rm -rf dist && bun build src/server.ts --outdir=dist --target=bun --packages=external",
    "typecheck": "bun x tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@atlas-kb/errors": "workspace:*",
    "@atlas-kb/mastra": "workspace:*",
    "@atlas-kb/schema": "workspace:*",
    "@elysiajs/cors": "^1.4.1",
    "elysia": "^1.4.22",
    "jose": "6.2.1"
  }
}
