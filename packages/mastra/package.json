{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@atlas-kb/mastra",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./knowledge": "./src/knowledge/index.ts"
  },
  "scripts": {
    "dev": "mastra dev",
    "start": "mastra start",
    "build": "mastra build",
    "typecheck": "bun x tsc -p tsconfig.json --noEmit",
    "db:codegen": "kysely-codegen --env-file ../../.env --url 'env(DATABASE_URL)' --dialect postgres --default-schema public --default-schema atlas_kb_mastra --out-file src/knowledge/db.generated.ts",
    "fixtures:import": "bun run src/scripts/import-department-fixtures.ts",
    "agent:smoke": "bun run src/scripts/run-department-agent-smoke.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.51",
    "@atlas-kb/errors": "workspace:*",
    "@atlas-kb/schema": "workspace:*",
    "@aws-sdk/client-s3": "^3.1025.0",
    "@aws-sdk/s3-request-presigner": "^3.1025.0",
    "@mastra/core": "1.13.2",
    "@mastra/memory": "1.13.1",
    "@mastra/pg": "^1.8.3",
    "@mastra/qdrant": "^1.0.2",
    "@mastra/s3": "^0.3.0",
    "ai": "*",
    "kysely": "^0.28.15",
    "kysely-postgres-js": "^3.0.0",
    "postgres": "^3.4.8",
    "tokenx": "1.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "kysely-codegen": "^0.20.0"
  }
}
