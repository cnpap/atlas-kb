{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@atlas-kb/mastra",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./knowledge": "./src/knowledge/index.ts"
  },
  "scripts": {
    "dev": "mastra dev",
    "start": "mastra start",
    "build": "mastra build",
    "fixtures:import": "bun run src/scripts/import-department-fixtures.ts",
    "agent:smoke": "bun run src/scripts/run-department-agent-smoke.ts"
  },
  "dependencies": {
    "@atlas-kb/errors": "workspace:*",
    "@atlas-kb/schema": "workspace:*",
    "@mastra/core": "*",
    "@mastra/libsql": "*",
    "@mozilla/readability": "0.6.0",
    "jsdom": "29.0.1",
    "mammoth": "1.12.0",
    "pdf-parse": "2.4.5"
  }
}
