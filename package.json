{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "atlas-kb",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "api:dev": "bun --env-file=.env run --filter @atlas-kb/api dev",
    "api:start": "bun --env-file=.env run --filter @atlas-kb/api start",
    "api:build": "bun run --filter @atlas-kb/api build",
    "dev": "bun --env-file=.env run --filter @atlas-kb/mastra dev",
    "start": "bun --env-file=.env run --filter @atlas-kb/mastra start",
    "build": "bun run --filter @atlas-kb/mastra build",
    "web:dev": "bun --env-file=.env run --filter @atlas-kb/web dev",
    "web:build": "bun run --filter @atlas-kb/web build",
    "web:preview": "bun --env-file=.env run --filter @atlas-kb/web preview",
    "web:typecheck": "bun run --filter @atlas-kb/web typecheck",
    "test": "bun test",
    "lint:biome": "biome lint .",
    "lint": "bun run lint:biome && bun run web:typecheck",
    "format": "biome format . --write"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "^1.4.6",
    "@mastra/core": "1.13.2",
    "@mastra/libsql": "1.6.4",
    "elysia": "^1.4.22",
    "mastra": "^1.3.5",
    "vue": "^3.5.29",
    "vue-router": "^4.5.1",
    "zod": "^4.3.6"
  },
  "overrides": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "^1.4.6",
    "@mastra/core": "1.13.2",
    "@mastra/libsql": "1.6.4",
    "elysia": "^1.4.22",
    "mastra": "^1.3.5",
    "vue": "^3.5.29",
    "vue-router": "^4.5.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@types/bun": "latest",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.1.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
