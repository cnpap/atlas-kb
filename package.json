{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "atlas-kb",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "api:dev": "bun --env-file=.env run --filter @atlas-kb/api dev",
    "api:start": "bun --env-file=.env run --filter @atlas-kb/api start",
    "api:build": "bun run --filter @atlas-kb/api build",
    "fixtures:import": "bun --env-file=.env run --filter @atlas-kb/mastra fixtures:import",
    "agent:smoke": "bun --env-file=.env run --filter @atlas-kb/mastra agent:smoke",
    "mastra:dev": "bun --env-file=.env run --filter @atlas-kb/mastra dev",
    "mastra:start": "bun --env-file=.env run --filter @atlas-kb/mastra start",
    "mastra:build": "bun run --filter @atlas-kb/mastra build",
    "mastra:db:codegen": "bun --env-file=.env run --filter @atlas-kb/mastra db:codegen",
    "dev": "bun --env-file=.env run --parallel --filter @atlas-kb/api --filter @atlas-kb/web dev",
    "start": "bun run api:start",
    "build": "bun run api:build && bun run web:build",
    "web:dev": "bun --env-file=.env run --filter @atlas-kb/web dev",
    "web:build": "bun run --filter @atlas-kb/web build",
    "web:preview": "bun --env-file=.env run --filter @atlas-kb/web preview",
    "web:typecheck": "bun run --filter @atlas-kb/web typecheck",
    "api:typecheck": "bun run --filter @atlas-kb/api typecheck",
    "mastra:typecheck": "bun run --filter @atlas-kb/mastra typecheck",
    "typecheck": "bun run api:typecheck && bun run mastra:typecheck && bun run web:typecheck",
    "test": "bun --env-file=.env test packages/schema/src/*.test.ts packages/api/src/*.test.ts packages/mastra/src/knowledge/*.test.ts",
    "test:e2e": "playwright test",
    "lint:biome": "biome lint .",
    "lint": "bun run lint:biome && bun run typecheck",
    "format": "biome format . --write"
  },
  "dependencies": {
    "@mastra/core": "1.13.2",
    "mastra": "^1.3.5"
  },
  "overrides": {
    "ai": "6.0.138",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "^1.4.6",
    "@mastra/core": "1.13.2",
    "@mastra/pg": "1.8.3",
    "elysia": "^1.4.22",
    "mastra": "^1.3.5",
    "vue": "^3.5.29",
    "vue-router": "^4.5.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@playwright/test": "^1.59.1",
    "@types/bun": "1.3.10",
    "@types/node": "^24.10.1",
    "playwright": "^1.58.2",
    "typescript": "~5.9.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
