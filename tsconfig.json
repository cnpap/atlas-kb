{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "allowJs": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "baseUrl": ".",
    "paths": {
      "@atlas-kb/schema": ["./packages/schema/src/index.ts"],
      "@atlas-kb/errors": ["./packages/errors/src/index.ts"],
      "@atlas-kb/mastra": ["./packages/mastra/src/index.ts"],
      "@atlas-kb/mastra/knowledge": [
        "./packages/mastra/src/knowledge/index.ts"
      ],
      "@atlas-kb/api": ["./packages/api/src/index.ts"]
    }
  }
}
