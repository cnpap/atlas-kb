COMPOSE_PROJECT_NAME=atlas-kb-admin
ATLAS_KB_DOCKER_NETWORK=atlas-app-network
ATLAS_KB_ADMIN_IMAGE=atlas-kb-admin:local
ATLAS_KB_ADMIN_HOST_PORT=8000
OCTANE_SERVER=swoole
OCTANE_HOST=0.0.0.0
OCTANE_PORT=8000
OCTANE_WORKERS=4
OCTANE_TASK_WORKERS=2
OCTANE_MAX_REQUESTS=500
OCTANE_HTTPS=false

APP_NAME="Atlas KB Admin"
APP_ENV=production
APP_KEY=base64:change-me
APP_DEBUG=false
APP_URL=http://localhost:8000

APP_LOCALE=zh_CN
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=postgres.example.internal
DB_PORT=5432
DB_DATABASE=atlas_kb
DB_USERNAME=atlas_kb
DB_PASSWORD=change-me

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

KB_TEMPLATE_STORAGE_DISK=kb_templates
KB_TEMPLATE_STORAGE_DIRECTORY=kb/templates
KB_TEMPLATE_PARSER_VERSION=ooxml-v1
KB_TEMPLATE_AWS_ACCESS_KEY_ID=change-me
KB_TEMPLATE_AWS_SECRET_ACCESS_KEY=change-me
KB_TEMPLATE_AWS_DEFAULT_REGION=us-east-1
KB_TEMPLATE_AWS_BUCKET=atlas-kb
KB_TEMPLATE_AWS_URL=
KB_TEMPLATE_AWS_ENDPOINT=http://rustfs.example.internal:9000
KB_TEMPLATE_AWS_USE_PATH_STYLE_ENDPOINT=true
KB_TEMPLATE_EXPORT_STORAGE_DISK=kb_templates
KB_TEMPLATE_EXPORT_STORAGE_DIRECTORY=kb/template-exports
KB_TEMPLATE_EXPORT_RETENTION_DAYS=30
KB_TEMPLATE_AI_ENABLED=true
KB_TEMPLATE_AI_BASE_URL=
KB_TEMPLATE_AI_API_KEY=
KB_TEMPLATE_AI_MODEL=
KB_TEMPLATE_AI_TIMEOUT=60
KB_TEMPLATE_AI_FALLBACK_ENV_PATH=

ATLAS_KB_INTERNAL_SECRET=change-me
ATLAS_KB_PUBLIC_API_BASE_URL=http://atlas-kb-api:6112
ATLAS_KB_CONNECT_TIMEOUT=10
ATLAS_KB_REQUEST_TIMEOUT=900

VITE_APP_NAME="${APP_NAME}"
