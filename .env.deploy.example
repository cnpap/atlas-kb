COMPOSE_PROJECT_NAME=atlas-kb
ATLAS_KB_DOCKER_NETWORK=atlas-app-network

ATLAS_KB_API_IMAGE=atlas-kb-api:local
ATLAS_KB_WEB_IMAGE=atlas-kb-web:local

ATLAS_KB_API_HOST_PORT=6112
ATLAS_KB_API_CONTAINER_PORT=6112
ATLAS_KB_WEB_HOST_PORT=6111

API_HOST=0.0.0.0
API_PORT=6112
VITE_API_BASE_URL=/
WEB_ALLOWED_HOSTS=localhost,127.0.0.1

ATLAS_KB_DEFAULT_USERNAME=admin
ATLAS_KB_DEFAULT_PASSWORD=change-me
ATLAS_KB_JWT_SECRET=change-me
ATLAS_KB_INTERNAL_SECRET=change-me
ATLAS_KB_ADMIN_API_BASE_URL=http://atlas-kb-admin-web:8000
ATLAS_KB_PUBLIC_API_BASE_URL=http://atlas-kb-api:6112

DATABASE_URL=postgresql://atlas_kb:change-me@postgres.example.internal:5432/atlas_kb
TIMESCALEDB_URL=postgresql://atlas_kb:change-me@postgres.example.internal:5432/atlas_kb

QDRANT_URL=http://qdrant.example.internal:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=atlas_kb

ATLAS_KB_S3_ENDPOINT=http://rustfs.example.internal:9000
ATLAS_KB_S3_REGION=us-east-1
ATLAS_KB_S3_BUCKET=atlas-kb
ATLAS_KB_S3_ACCESS_KEY_ID=change-me
ATLAS_KB_S3_SECRET_ACCESS_KEY=change-me
ATLAS_KB_S3_PREFIX=knowledge-sources
ATLAS_KB_S3_FORCE_PATH_STYLE=true

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

RUNTIME_PROVIDER=openai
RUNTIME_MODEL=

EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=
