APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=zh_CN
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=15432
DB_DATABASE=atlas_kb_admin
DB_USERNAME=ops_agent_kit
DB_PASSWORD=change-me

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

KB_TEMPLATE_STORAGE_DISK=kb_templates
KB_TEMPLATE_STORAGE_DIRECTORY=kb/templates
KB_TEMPLATE_PARSER_VERSION=ooxml-v1
KB_TEMPLATE_AWS_ACCESS_KEY_ID=
KB_TEMPLATE_AWS_SECRET_ACCESS_KEY=
KB_TEMPLATE_AWS_DEFAULT_REGION=us-east-1
KB_TEMPLATE_AWS_BUCKET=ops-agent-kit
KB_TEMPLATE_AWS_URL=
KB_TEMPLATE_AWS_ENDPOINT=http://127.0.0.1:9000
KB_TEMPLATE_AWS_USE_PATH_STYLE_ENDPOINT=true
KB_TEMPLATE_EXPORT_STORAGE_DISK=kb_templates
KB_TEMPLATE_EXPORT_STORAGE_DIRECTORY=kb/template-exports
KB_TEMPLATE_EXPORT_RETENTION_DAYS=30
KB_TEMPLATE_AI_ENABLED=true
KB_TEMPLATE_AI_BASE_URL=
KB_TEMPLATE_AI_API_KEY=
KB_TEMPLATE_AI_MODEL=
KB_TEMPLATE_AI_TIMEOUT=60
KB_TEMPLATE_AI_FALLBACK_ENV_PATH=/root/code/ops-agent-kit/.env
ATLAS_KB_INTERNAL_SECRET=change-me
ATLAS_KB_PUBLIC_API_BASE_URL=http://127.0.0.1:6112

VITE_APP_NAME="${APP_NAME}"
